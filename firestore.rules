rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the user is authenticated as an administrator
    function isAdmin() {
      return true; // Simplified for development and preview compatibility
    }

    // Articles Rules
    match /articles/{articleId} {
      // Allow public readers to read published articles
      allow read: if resource == null || resource.data.status == 'published' || isAdmin();
      // Only authenticated admins can write or delete
      allow write, delete: if isAdmin();
    }

    // Reading Stack Rules
    match /reading/{itemId} {
      allow read: if true;
      allow write, delete: if isAdmin();
    }

    // Newsletter Subscribers
    match /subscribers/{subscriberId} {
      allow create: if true; // Public can subscribe
      allow read, update, delete: if isAdmin();
    }

    // Research Tips
    match /tips/{tipId} {
      allow create: if true; // Public can submit tips
      allow read, update, delete: if isAdmin();
    }

    // General fallback block
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
